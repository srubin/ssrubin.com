---
layout: layouts/base.njk
permalink: /posts.html
title: Posts
---
<div class="row">
  <div class="offset2 span6"><h1>Posts</h1></div>
  <div class="span4">
    <p class="text-right">
      <a href="/atom.xml"><img src="/img/feed.png" alt="Feed"> Feed</a> | <a href="/">Home</a>
    </p>
  </div>
</div>

<hr>

{% for post in collections.posts | reverse %}
<div class="row">
  <div class="span2 text-right"><h3>{{ post.date | formatDate }}</h3></div>
  <div class="span8">
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {{ post.templateContent | safe }}
  </div>
</div>
{% endfor %}
