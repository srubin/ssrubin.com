---
layout: layouts/base.njk
---
<div class="row">
  <div class="span2 text-right">
    <h3>{{ page.date | formatDate }}</h3>
  </div>
  <div class="span6">
    <h1><em class="muted">#</em> <a href="{{ page.url }}">{{ title }}</a></h1>
  </div>
  <div class="span4">
    <p class="text-right">
      <a href="/posts.html">Posts</a> | <a href="/">Home</a>
    </p>
  </div>
</div>

<hr>

<div class="row">
  <div class="offset2 span8">
    {{ content | safe }}
  </div>
</div>

<hr>

<div class="row">
  <div class="offset2 span8">
    {% include "partials/disqus.njk" %}
  </div>
</div>
