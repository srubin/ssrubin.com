<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="keywords" content="{{ site.keywords }}{% if keywords %}, {{ keywords }}{% endif %}">
  <meta name="author" content="{{ site.author }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <link rel="alternate" type="application/atom+xml" href="/atom.xml" title="{{ site.title }}'s blog">

  <link href="https://fonts.googleapis.com/css?family=PT+Sans:700|PT+Serif:400,400italic,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/style.css">
</head>
<body>
  <div class="container">
    <section id="content" class="content">
      {{ content | safe }}
    </section>
  </div>

  <!-- Web analytics snippet goes here -->
</body>
</html>
